<?xml version="1.0" encoding="utf-8"?>
<!-- Customer display: standby | selecting | payment | success -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1A14">

    <!-- 1) Standby -->
    <LinearLayout
        android:id="@+id/panelStandby"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/standbyBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="#C4A35A"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/standbyTagline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/customer_standby_welcome"
            android:textColor="#A8B5AE"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/standbyPromoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="@string/customer_standby_recommend_label"
            android:textColor="#7A8A82"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/standbyPromo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="#F3F6F2"
            android:textSize="28sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/standbyPromoImage"
            android:layout_width="220dp"
            android:layout_height="138dp"
            android:layout_marginTop="18dp"
            android:background="#1A2A22"
            android:contentDescription="@string/customer_standby_recommend_label"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/standbyFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:textColor="#5C6B64"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- 2) Selecting -->
    <LinearLayout
        android:id="@+id/panelSelecting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/selectTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/customer_select_title"
            android:textColor="#C4A35A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/selectLines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <TextView
            android:id="@+id/selectDiscount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#E85D24"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/selectTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:paddingTop="6dp"
            android:textColor="#F3F6F2"
            android:textSize="40sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 3) Payment -->
    <LinearLayout
        android:id="@+id/panelPayment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/payTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/customer_pay_title"
            android:textColor="#C4A35A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/payTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#F3F6F2"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/payHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="#A8B5AE"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/payQr"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF"
            android:contentDescription="@string/customer_pay_qr_hint"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/payCashDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:textColor="#F3F6F2"
            android:textSize="22sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 4) Success -->
    <LinearLayout
        android:id="@+id/panelSuccess"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/successTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/customer_success_title"
            android:textColor="#C4A35A"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/successAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#F3F6F2"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/successMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:textColor="#A8B5AE"
            android:textSize="20sp" />
    </LinearLayout>
</FrameLayout>
