<?xml version="1.0" encoding="utf-8"?>
<!-- Clone web PosOptionPickerModal (FoodStory hero + groups + orange CTA) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E2D3D"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/optionHeroImage"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="#2A3C4E"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/optionHeroName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F7F8FC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optionHeroPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#F0C9A0"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/optionQtyMinus"
                    android:layout_width="40dp"
                    android:layout_height="36dp"
                    android:backgroundTint="#2A3C4E"
                    android:minWidth="40dp"
                    android:minHeight="36dp"
                    android:text="−"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/optionQtyValue"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/optionQtyPlus"
                    android:layout_width="40dp"
                    android:layout_height="36dp"
                    android:backgroundTint="#E85D24"
                    android:minWidth="40dp"
                    android:minHeight="36dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="360dp">

        <LinearLayout
            android:id="@+id/optionGroupsRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp" />
    </ScrollView>

    <TextView
        android:id="@+id/optionPickerError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:textColor="#C0392B"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7F8FC"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/optionLineTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#1E2D3D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/optionCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#EEF0F4"
            android:minHeight="44dp"
            android:text="@android:string/cancel"
            android:textAllCaps="false"
            android:textColor="#1E2D3D" />

        <Button
            android:id="@+id/optionConfirm"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:backgroundTint="#E85D24"
            android:minHeight="44dp"
            android:text="@string/btn_add_to_cart"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
