<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#102018"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/captureProbeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TellTea nPos"
        android:textColor="#C4A35A"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/captureProbeBody"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="#F3F6F2"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/captureProbeMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#A8B5AD"
        android:textSize="14sp" />
</LinearLayout>
