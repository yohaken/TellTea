<?xml version="1.0" encoding="utf-8"?>
<!-- Top-left update popup — visible on sell/hub without opening Settings -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/updatePopup"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_gravity="top|start"
    android:layout_marginStart="12dp"
    android:layout_marginTop="12dp"
    android:background="#FFFFFFFF"
    android:elevation="10dp"
    android:orientation="vertical"
    android:padding="14dp"
    android:visibility="gone">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/update_popup_title"
        android:textColor="#1E2D3D"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/updatePopupBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#5A6570"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/updatePopupProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#E85D24"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/updatePopupLater"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/npos_touch_ghost"
            android:gravity="center"
            android:minHeight="44dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="@string/update_popup_later"
            android:textColor="#1E2D3D"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/updatePopupGo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/npos_nav_active"
            android:gravity="center"
            android:minHeight="44dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="@string/btn_install_update"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
