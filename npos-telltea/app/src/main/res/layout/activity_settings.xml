<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7F7F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="#1A2E24"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/settings_hint"
            android:textColor="#666666"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/settingsVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="#1A2E24"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1A2E24"
            android:padding="14dp"
            android:text="@string/banner_update"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/status_ready"
            android:textColor="#555555"
            android:textSize="14sp" />

        <Button
            android:id="@+id/updateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="@string/btn_check_update"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/installPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_open_install_page"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/settings_section_hardware"
            android:textColor="#1A2E24"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/diagnoseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="52dp"
            android:text="@string/btn_diagnose"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/settings_section_customer"
            android:textColor="#1A2E24"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/customer_test_hint"
            android:textColor="#666666"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/customerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/customer_test_idle"
            android:textColor="#555555"
            android:textSize="14sp" />

        <Button
            android:id="@+id/customerAmount1Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_customer_amount_1"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/customerAmount2Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_customer_amount_2"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/customerCloseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_customer_close"
            android:textAllCaps="false" />
    </LinearLayout>
</ScrollView>
