<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7F7F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="#1A2E24"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/settings_hint"
            android:textColor="#666666"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/settings_section_device"
            android:textColor="#1A2E24"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/settingsVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#1A2E24"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1A2E24"
            android:padding="14dp"
            android:text="@string/banner_update"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/status_ready"
            android:textColor="#555555"
            android:textSize="14sp" />

        <Button
            android:id="@+id/updateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="@string/btn_check_update"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/installPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_open_install_page"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/openMenuAdminButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_open_menu_admin"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/menu_admin_hint"
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/settings_section_printer"
            android:textColor="#1A2E24"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/printer_hint"
            android:textColor="#666666"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/printerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/printer_idle"
            android:textColor="#555555"
            android:textSize="14sp" />

        <Button
            android:id="@+id/printerScanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_printer_scan"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/printerNextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_printer_next"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/printerTestButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_printer_test"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/drawerKickButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_drawer_kick"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/printer_lan_title"
            android:textColor="#1A2E24"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/printerLanHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/printer_lan_host_hint"
            android:inputType="text"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/printerLanPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="@string/printer_lan_port_hint"
            android:inputType="number"
            android:minHeight="48dp"
            android:text="9100" />

        <Button
            android:id="@+id/printerLanAddButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="48dp"
            android:text="@string/btn_printer_lan_add"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_tech"
            android:textColor="#1A2E24"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/settings_tech_hint"
            android:textColor="#666666"
            android:textSize="13sp" />

        <Button
            android:id="@+id/diagnoseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/btn_diagnose"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_section_customer"
            android:textColor="#1A2E24"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/customerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/customer_test_idle"
            android:textColor="#555555"
            android:textSize="13sp" />

        <Button
            android:id="@+id/customerAmount1Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="44dp"
            android:text="@string/btn_customer_amount_1"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/customerAmount2Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="44dp"
            android:text="@string/btn_customer_amount_2"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/customerCloseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="44dp"
            android:text="@string/btn_customer_close"
            android:textAllCaps="false" />
    </LinearLayout>
</ScrollView>
