<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF0F4">

    <!-- Clock-in (shift closed) -->
    <ScrollView
        android:id="@+id/clockInPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="@string/app_name"
                android:textColor="#1A2E24"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/clock_in_title"
                android:textColor="#222222"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/clockInTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:textColor="#1A2E24"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/clockInDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#666666"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/deviceIdView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="#1A2E24"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/heartbeatStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="@string/heartbeat_idle"
                android:textColor="#666666"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#888888"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/permStatusView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:textColor="#8A4B12"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/grantPermsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:minHeight="56dp"
                android:text="@string/btn_grant_all_perms"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/openShiftButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:minHeight="56dp"
                android:text="@string/btn_open_shift"
                android:textAllCaps="false"
                android:textSize="18sp" />

            <Button
                android:id="@+id/settingsButtonClock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:minHeight="48dp"
                android:text="@string/btn_settings_device"
                android:textAllCaps="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/clock_in_hint"
                android:textColor="#777777"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

    <!-- Hub after clock-in — web PosAppShell left rail + content -->
    <LinearLayout
        android:id="@+id/sellPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <include layout="@layout/include_pos_sidebar" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A2E24"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/sellStatusStrip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/hub_title"
                    android:textColor="#F3F6F2"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sellDeviceCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#C4A35A"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/hubShiftStrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#243B32"
                android:padding="10dp"
                android:textColor="#D7E3DC"
                android:textSize="12sp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/hubNavList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:visibility="gone" />
            </ScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="@string/hub_rail_hint"
                android:textColor="#5A6570"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="10dp">

                <Button
                    android:id="@+id/closeShiftButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:minHeight="48dp"
                    android:text="@string/btn_close_shift"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/settingsButtonSell"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minHeight="48dp"
                    android:text="@string/btn_settings_device"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <include layout="@layout/include_update_popup" />
</FrameLayout>
