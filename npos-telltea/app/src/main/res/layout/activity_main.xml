<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7F7F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A2E24"
            android:padding="14dp"
            android:text="@string/banner_update"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="@string/app_name"
            android:textColor="#1A2E24"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/hello"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/hello_world"
            android:textColor="#222222"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:textColor="#1A2E24"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/status_ready"
            android:textColor="#555555"
            android:textSize="15sp" />

        <Button
            android:id="@+id/updateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="52dp"
            android:text="@string/btn_check_update"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/diagnoseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="52dp"
            android:text="@string/btn_diagnose"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/installPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="52dp"
            android:text="@string/btn_open_install_page"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/install_page_hint"
            android:textColor="#777777"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
