<?xml version="1.0" encoding="utf-8"?>
<!-- Web PosAppShell: left sidebar + sell body (PosSellView 65/35) + update popup -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF0F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <include layout="@layout/include_pos_sidebar" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E2D3D"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/sellTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sell_title"
                    android:textColor="#F7F8FC"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sellVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="#2A3C4E"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="#F0C9A0"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/refreshMenuButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/npos_touch_ghost"
                    android:gravity="center"
                    android:minHeight="40dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:text="@string/btn_refresh_menu"
                    android:textColor="#1E2D3D"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sellSyncStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F0C9A0"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/shiftSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2A3C4E"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:textColor="#D7E0EA"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:padding="6dp">

                <!-- Left ~65%: categories + menu grid -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="65"
                    android:orientation="vertical">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/categoryBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingBottom="6dp"
                            android:paddingTop="2dp" />
                    </HorizontalScrollView>

                    <ScrollView
                        android:id="@+id/menuScroll"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fillViewport="true"
                        android:overScrollMode="never"
                        android:scrollbars="vertical">

                        <GridLayout
                            android:id="@+id/menuGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:alignmentMode="alignBounds"
                            android:columnCount="5"
                            android:padding="2dp"
                            android:useDefaultMargins="false" />
                    </ScrollView>
                </LinearLayout>

                <!-- Right ~35%: cart + totals + pay -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="35"
                    android:background="#FFFFFF"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cart_title"
                        android:textColor="#1E2D3D"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/priceChannelToggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/npos_touch_ghost"
                        android:gravity="center"
                        android:minHeight="36dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="@string/price_channel_store"
                        android:textColor="#1E2D3D"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/clearCartButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/npos_touch_ghost"
                        android:gravity="center"
                        android:minHeight="36dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="@string/btn_clear_cart"
                        android:textColor="#B45309"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">

                        <LinearLayout
                            android:id="@+id/cartList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </ScrollView>

                    <TextView
                        android:id="@+id/cartTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/cart_total_zero"
                        android:textColor="#1E2D3D"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/discountLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E85D24"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/discountButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:backgroundTint="#FFFFFF"
                            android:minHeight="40dp"
                            android:text="@string/btn_discount"
                            android:textAllCaps="false"
                            android:textColor="#E85D24" />

                        <Button
                            android:id="@+id/holdBillButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:backgroundTint="#FFFFFF"
                            android:minHeight="40dp"
                            android:text="@string/btn_hold_bill"
                            android:textAllCaps="false"
                            android:textColor="#E85D24" />

                        <Button
                            android:id="@+id/restoreHoldButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:backgroundTint="#FFFFFF"
                            android:minHeight="40dp"
                            android:text="@string/btn_restore_hold"
                            android:textAllCaps="false"
                            android:textColor="#E85D24" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/flushSyncButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="36dp"
                        android:text="@string/btn_flush_sync"
                        android:textAllCaps="false"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/payCashButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/npos_touch_primary"
                        android:gravity="center"
                        android:minHeight="64dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:text="@string/btn_pay_cash"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/payPromptButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/npos_touch_secondary"
                        android:gravity="center"
                        android:minHeight="52dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:text="@string/btn_pay_promptpay"
                        android:textColor="#E85D24"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/xReportButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/npos_touch_ghost"
                        android:gravity="center"
                        android:minHeight="44dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:text="@string/btn_x_report"
                        android:textColor="#1E2D3D"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Kept for code wiring; nav moved to left rail -->
                    <Button
                        android:id="@+id/backButton"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                    <Button
                        android:id="@+id/receiptsButton"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                    <Button
                        android:id="@+id/sellSettingsButton"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                    <Button
                        android:id="@+id/sellCloseShiftButton"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <include layout="@layout/include_update_popup" />
</FrameLayout>
