<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F5"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A2E24"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/sellTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/sell_title"
            android:textColor="#F3F6F2"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/refreshMenuButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:minHeight="40dp"
            android:text="@string/btn_refresh_menu"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/sellSyncStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C4A35A"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/shiftSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#243B32"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:textColor="#D7E3DC"
        android:textSize="12sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/categoryBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp" />
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2">

            <LinearLayout
                android:id="@+id/menuList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cart_title"
                android:textColor="#1A2E24"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/cartList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <TextView
                android:id="@+id/cartTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/cart_total_zero"
                android:textColor="#1A2E24"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/discountLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8A6A2F"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/discountButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:minHeight="40dp"
                android:text="@string/btn_discount"
                android:textAllCaps="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/holdBillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:minHeight="40dp"
                    android:text="@string/btn_hold_bill"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/restoreHoldButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:minHeight="40dp"
                    android:text="@string/btn_restore_hold"
                    android:textAllCaps="false" />
            </LinearLayout>

            <Button
                android:id="@+id/flushSyncButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="36dp"
                android:text="@string/btn_flush_sync"
                android:textAllCaps="false"
                android:visibility="gone" />

            <Button
                android:id="@+id/payCashButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="48dp"
                android:text="@string/btn_pay_cash"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/payPromptButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:minHeight="44dp"
                android:text="@string/btn_pay_promptpay"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/receiptsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/btn_receipts"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/xReportButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/btn_x_report"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/sellSettingsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/btn_settings"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/sellCloseShiftButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/btn_close_shift"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
