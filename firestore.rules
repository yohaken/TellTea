rules_version = '2';
// Canonical Firestore rules for Firebase project mypeer-501909 (TellTea + shared apps).
// Sibling sites (e.g. taxtag.web.app) MUST NOT deploy their own firestore.rules —
// that wipes this file and locks the shop out. Hosting-only deploy for siblings.
// See scripts/templates/SHARED_FIREBASE_CHECKLIST.md and scripts/assert-firestore-rules.mjs
service cloud.firestore {
  match /databases/{database}/documents {
    function hasEmail() {
      return request.auth != null && request.auth.token.email != null;
    }

    function hasPhone() {
      return request.auth != null && request.auth.token.phone_number != null;
    }

    function signedIn() {
      return hasEmail() || hasPhone();
    }

    function authEmail() {
      return hasEmail() ? request.auth.token.email.lower() : '';
    }

    function authPhone() {
      return hasPhone() ? request.auth.token.phone_number : '';
    }

    function phoneDigits() {
      return hasPhone() && authPhone().size() > 1 ? authPhone()[1:] : '';
    }

    function resolvedStaffId() {
      return hasEmail()
        ? authEmail()
        : get(/databases/$(database)/documents/staffPhones/$(phoneDigits())).data.staffId;
    }

    function staffPath() {
      return /databases/$(database)/documents/staff/$(resolvedStaffId());
    }

    function isStaff() {
      return signedIn() && exists(staffPath());
    }

    function isOwner() {
      return isStaff() && get(staffPath()).data.role == 'owner';
    }

    function isOwnerEmail() {
      return hasEmail() && authEmail() == 'yohaken@gmail.com';
    }

    // ศูนย์รวมพนักงาน — list + get ต้องผ่านทั้งคู่ใน query
    function staffHubManage() {
      return isOwner() || hasPerm('staffManage') || isOwnerEmail();
    }

    function actorId() {
      return hasEmail() ? authEmail() : authPhone();
    }

    // Fine-grained permissions on staff doc; owners always pass.
    // Staff without permissions map: ledger+stock only (legacy default).
    function hasPerm(p) {
      return isOwner()
        || (isStaff()
            && get(staffPath()).data.keys().hasAny(['permissions'])
            && get(staffPath()).data.permissions[p] == true)
        || (isStaff()
            && !get(staffPath()).data.keys().hasAny(['permissions'])
            && (p == 'ledger' || p == 'stock' || p == 'production' || p == 'otBonus' || p == 'checklist' || p == 'bonus'));
    }

    function staffSelfProfileUpdate() {
      let before = resource.data;
      let after = request.resource.data;
      return after.role == before.role
        && after.createdAt == before.createdAt
        && after.diff(before).affectedKeys()
            .hasOnly([
              'displayName',
              'employeeId',
              'profileComplete',
              'profileSnoozeUntil',
              'personalProfileComplete',
            ]);
    }

    function employeeSelfLinkUpdate() {
      let before = resource.data;
      let after = request.resource.data;
      return after.diff(before).affectedKeys()
            .hasOnly(['linkedEmail', 'linkedPhone', 'linkedStaffId', 'updatedAt'])
        && (
          (hasEmail() && after.linkedEmail == authEmail())
          || (hasPhone() && after.linkedPhone == authPhone())
        )
        && (
          !after.keys().hasAny(['linkedEmail', 'linkedPhone', 'linkedStaffId'])
          || !before.keys().hasAny(['linkedEmail', 'linkedPhone', 'linkedStaffId'])
          || (hasEmail() && before.linkedEmail == authEmail())
          || (hasPhone() && before.linkedPhone == authPhone())
          || (before.keys().hasAny(['linkedStaffId']) && before.linkedStaffId == resolvedStaffId())
        );
    }

    // พนักงานกรอก/แก้รายการได้ — เปลี่ยนสถานะจ่ายโบนัสได้เฉพาะเจ้าของ
    function bonusEntryStaffUpdate() {
      let before = resource.data;
      let after = request.resource.data;
      return before.status != 'paid'
        && after.status == before.status
        && after.createdBy == before.createdBy
        && after.createdAt == before.createdAt;
    }

    function prodEntryCreate() {
      return request.resource.data.createdBy == actorId()
        && request.resource.data.productName is string
        && request.resource.data.qtyProduced is number
        && request.resource.data.qtyProduced > 0
        && request.resource.data.status == 'unpaid';
    }

    function otEntryCreate() {
      return request.resource.data.createdBy == actorId()
        && request.resource.data.shift is string
        && request.resource.data.machineCount is number
        && request.resource.data.status in ['pending', 'unpaid'];
    }

    function isPosDeviceAuth() {
      return request.auth != null
        && (
          request.auth.token.posDevice == true
          || request.auth.token.firebase.sign_in_provider == 'anonymous'
        );
    }

    function posDeviceCreate() {
      return isPosDeviceAuth()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.registeredAt is number
        && request.resource.data.lastSeenAt is number
        && request.resource.data.appBuild is number
        && request.resource.data.pairingCode is string
        && request.resource.data.pairingCode.size() >= 4;
    }

    function posDeviceHeartbeat() {
      let before = resource.data;
      let after = request.resource.data;
      let repairAuth = !before.keys().hasAll(['authUid']) || before.authUid == '';
      let telemetryKeys = [
        'deviceHint', 'printerLabel', 'printerReady', 'standalone', 'screenSize', 'platform', 'telemetryAt',
        'shellKind', 'nativeShellBuild',
        'updateStatus', 'updateTargetBuild', 'updateError', 'updateCheckedAt',
        'lastOwnerPingAckAt',
      ];
      let baseKeys = [
        'lastSeenAt', 'appBuild', 'userAgent', 'lastReloadAckAt',
        'syncPendingCount', 'syncFailedCount', 'syncStuckAt', 'syncLastError', 'updatedAt',
      ];
      let allowedKeys = repairAuth
        ? baseKeys.concat(telemetryKeys).concat(['authUid'])
        : baseKeys.concat(telemetryKeys);
      return isPosDeviceAuth()
        && (repairAuth || before.authUid == request.auth.uid)
        && after.authUid == request.auth.uid
        && (!before.keys().hasAll(['registeredAt']) || after.registeredAt == before.registeredAt)
        && (!before.keys().hasAll(['pairingCode']) || after.pairingCode == before.pairingCode)
        && after.diff(before).affectedKeys().hasOnly(allowedKeys);
    }

    function posMenuCategoryCreate() {
      return isPosDeviceAuth()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.sortOrder is number
        && request.resource.data.active is bool
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
    }

    function posMenuItemCreate() {
      return isPosDeviceAuth()
        && request.resource.data.categoryId is string
        && request.resource.data.categoryId.size() > 0
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.sortOrder is number
        && request.resource.data.active is bool
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
    }

    function posDeviceOwnerPatch() {
      let before = resource.data;
      let after = request.resource.data;
      return after.authUid == before.authUid
        && after.registeredAt == before.registeredAt
        && after.pairingCode == before.pairingCode
        && after.diff(before).affectedKeys().hasOnly([
          'label',
          'forceReloadAt',
          'ownerPingAt',
          'ownerPingMessage',
          'captureRequestAt',
          'captureIntervalMinutes',
          'updatedAt',
          'updatedBy',
          'disabled',
          'blocked',
          'deviceClass',
        ]);
    }

    function posMetaBillWrite() {
      return request.resource.data.billDate is number
        && request.resource.data.billSeq is number
        && request.resource.data.billSeq >= 1
        && request.resource.data.billSeq <= 9999;
    }

    function posActorId() {
      return 'pos:' + request.auth.uid;
    }

    function posSaleCreate() {
      return isPosDeviceAuth()
        && request.resource.data.deviceId == request.auth.uid
        && request.resource.data.sessionId is string
        && request.resource.data.date is number
        && request.resource.data.shift is string
        && request.resource.data.lines is list
        && request.resource.data.lines.size() > 0
        && request.resource.data.total is number
        && request.resource.data.total > 0
        && request.resource.data.paymentMethod in ['cash', 'promptpay']
        && request.resource.data.cashReceived is number
        && request.resource.data.change is number
        && request.resource.data.change >= 0
        && (
          (request.resource.data.paymentMethod == 'cash'
            && request.resource.data.cashReceived >= request.resource.data.total)
          || (request.resource.data.paymentMethod == 'promptpay'
            && request.resource.data.cashReceived == 0
            && request.resource.data.change == 0)
        )
        && request.resource.data.createdBy == posActorId()
        && request.resource.data.status == 'completed'
        && request.resource.data.billNo is string
        && request.resource.data.billNo.size() >= 5;
    }

    function posSessionOpen() {
      return isPosDeviceAuth()
        && request.resource.data.deviceId == request.auth.uid
        && request.resource.data.date is number
        && request.resource.data.shift is string
        && request.resource.data.status == 'open'
        && request.resource.data.openedAt is number;
    }

    function posSessionSaleBump() {
      let before = resource.data;
      let after = request.resource.data;
      return isPosDeviceAuth()
        && before.deviceId == request.auth.uid
        && after.deviceId == before.deviceId
        && after.status == 'open'
        && after.saleCount >= before.saleCount
        && after.totalSales >= before.totalSales;
    }

    function posSessionClose() {
      let before = resource.data;
      let after = request.resource.data;
      return isPosDeviceAuth()
        && before.deviceId == request.auth.uid
        && after.deviceId == before.deviceId
        && before.status == 'open'
        && after.status == 'closed'
        && after.closedAt is number
        && after.saleCount == before.saleCount
        && after.totalSales == before.totalSales;
    }

    function posMenuItemSoldOutToggle() {
      let before = resource.data;
      let after = request.resource.data;
      return isPosDeviceAuth()
        && after.diff(before).affectedKeys().hasOnly(['active', 'updatedAt'])
        && after.categoryId == before.categoryId
        && after.name == before.name
        && after.price == before.price
        && after.sortOrder == before.sortOrder
        && after.createdAt == before.createdAt
        && after.active is bool;
    }

    function staffEmployeeId() {
      return isStaff()
        && get(staffPath()).data.keys().hasAny(['employeeId'])
        && get(staffPath()).data.employeeId is string
        ? get(staffPath()).data.employeeId
        : '';
    }

    function isAssignTaskAssignee() {
      return staffEmployeeId() != ''
        && staffEmployeeId() in resource.data.assigneeIds;
    }

    function assignTaskCreate() {
      return request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.assigneeIds is list
        && request.resource.data.assigneeIds.size() > 0
        && request.resource.data.dueDate is number
        && request.resource.data.status == 'pending'
        && request.resource.data.createdBy == actorId();
    }

    function assignTaskStaffComplete() {
      let before = resource.data;
      let after = request.resource.data;
      return before.status == 'pending'
        && after.status == 'completed'
        && isAssignTaskAssignee()
        && after.proofImg is string
        && after.proofImg.size() > 0
        && after.title == before.title
        && after.note == before.note
        && after.assigneeIds == before.assigneeIds
        && after.assigneeNames == before.assigneeNames
        && after.dueDate == before.dueDate
        && after.recurrence == before.recurrence
        && after.checklist == before.checklist
        && after.createdBy == before.createdBy
        && after.createdAt == before.createdAt
        && after.assignedBy == before.assignedBy;
    }

    match /staff/{staffId} {
      allow get: if signedIn() && (staffId == resolvedStaffId() || staffHubManage());
      allow list: if staffHubManage();
      allow create: if staffHubManage()
        || (isOwnerEmail()
            && staffId == authEmail()
            && request.resource.data.email == authEmail()
            && request.resource.data.role == 'owner');
      allow update: if staffHubManage()
        || (signedIn() && staffId == resolvedStaffId() && staffSelfProfileUpdate());
      allow delete: if staffHubManage();
    }

    match /staffPhones/{phoneId} {
      allow get: if signedIn() && (phoneId == phoneDigits() || staffHubManage());
      allow write: if staffHubManage();
    }

    // ข้อมูลส่วนตัวละเอียดอ่อน — เจ้าของอ่านได้, พนักงานอ่าน/เขียนเฉพาะของตัวเอง
    match /staffPersonal/{staffId} {
      allow get: if isOwner() || (signedIn() && staffId == resolvedStaffId());
      allow list: if isOwner();
      allow create, update: if signedIn() && staffId == resolvedStaffId();
      allow delete: if isOwner();
    }

    match /ledger/{entryId} {
      allow read: if hasPerm('ledger');
      allow create: if (hasPerm('ledger')
        && request.resource.data.createdBy == actorId()
        && request.resource.data.description is string
        && request.resource.data.amountIn is number
        && request.resource.data.amountOut is number
        && request.resource.data.amountIn >= 0
        && request.resource.data.amountOut >= 0
        && (
          (request.resource.data.amountIn > 0 && request.resource.data.amountOut == 0 && hasPerm('transferIn'))
          || (request.resource.data.amountOut > 0 && request.resource.data.amountIn == 0)
        ));
      allow update, delete: if hasPerm('ledger');
    }

    match /ownerBooks/{entryId} {
      allow read, write: if hasPerm('ownerBooks');
    }

    /** One tax-evidence photo per doc — keeps ownerBooks/ledger rows small. */
    match /evidencePhotos/{photoId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          'dataUrl', 'contentType', 'fileName', 'folder', 'slotKey', 'createdBy', 'createdAt'
        ])
        && request.resource.data.dataUrl is string
        && request.resource.data.dataUrl.size() < 950000
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is number
        && request.resource.data.folder is string
        && request.resource.data.slotKey is string;
      allow update: if false;
      allow delete: if isOwner() || resource.data.createdBy == request.auth.uid;
    }

    match /monthlyIncome/{monthId} {
      allow read, write: if hasPerm('pnl');
    }

    match /stock/{itemId} {
      allow read: if hasPerm('stock');
      allow create, delete: if isOwner();
      allow update: if hasPerm('stock')
        && request.resource.data.name is string
        && request.resource.data.qty is number
        && request.resource.data.qty >= 0
        && request.resource.data.minQty is number
        && request.resource.data.minQty >= 0;
    }

    match /stockMovements/{logId} {
      allow read: if hasPerm('stock');
      allow create: if hasPerm('stock')
        && request.resource.data.itemId is string
        && request.resource.data.itemName is string
        && request.resource.data.type in ['IN', 'OUT', 'ADJUST']
        && request.resource.data.quantity is number
        && request.resource.data.quantity > 0
        && request.resource.data.date is number
        && request.resource.data.inspector is string
        && request.resource.data.createdBy == actorId();
      allow update, delete: if isOwner();
    }

    match /stockCountSessions/{sessionId} {
      allow read: if hasPerm('stock');
      allow create, update: if hasPerm('stock')
        && request.resource.data.date is number
        && request.resource.data.dayOfMonth in [1, 10, 20]
        && request.resource.data.year is int
        && request.resource.data.month is int
        && request.resource.data.inspector is string
        && request.resource.data.submittedAt is number
        && request.resource.data.createdBy == actorId()
        && request.resource.data.lines is list;
      allow delete: if isOwner();
    }

    // ศูนย์รวมรายชื่อพนักงานร้าน — เพิ่มที่เดียว ใช้ร่วมหลายหมวด
    match /employees/{id} {
      allow read: if isStaff();
      allow create, delete: if staffHubManage();
      allow update: if staffHubManage() || employeeSelfLinkUpdate();
    }

    // ผลิต / โบนัส — พนักงานกรอกแถว · เจ้าของตั้งสินค้า
    match /prodProducts/{id} {
      allow read: if hasPerm('production');
      allow write: if isOwner();
    }
    // legacy — ย้ายไป employees แล้ว
    match /prodWorkers/{id} {
      allow read: if isStaff();
      allow write: if staffHubManage();
    }
    match /prodEntries/{id} {
      allow read: if hasPerm('production');
      allow create: if hasPerm('production') && prodEntryCreate();
      allow update: if hasPerm('production')
        && (isOwner() || bonusEntryStaffUpdate());
      allow delete: if isOwner();
    }

    // โบนัสชงเครื่องดื่ม
    match /otEntries/{id} {
      allow read: if hasPerm('otBonus');
      allow create: if hasPerm('otBonus') && otEntryCreate();
      allow update: if hasPerm('otBonus')
        && (isOwner() || bonusEntryStaffUpdate());
      allow delete: if isOwner();
    }

    // SmartCheck SOP — บันทึกแนวตั้งต่อรายการ
    match /checklistItems/{id} {
      allow read: if hasPerm('checklist') || hasPerm('otBonus');
      allow write: if isOwner();
    }
    match /checklistRecords/{id} {
      allow read: if hasPerm('checklist') || hasPerm('otBonus');
      allow create: if (hasPerm('checklist') || hasPerm('otBonus'))
        && request.resource.data.createdBy == actorId()
        && request.resource.data.checkId is string
        && request.resource.data.itemName is string
        && request.resource.data.status in ['pass', 'fail']
        && (!request.resource.data.keys().hasAny(['sessionKind'])
          || request.resource.data.sessionKind in ['opening', 'closing', 'full']);
      allow delete: if isOwner();
      allow update: if false;
    }

    match /assignTasks/{id} {
      allow read, create, update, delete: if isOwnerEmail();
    }

    function isTaskOccurrenceAssignee() {
      return staffEmployeeId() != ''
        && staffEmployeeId() in resource.data.assigneeIds;
    }

    function taskOccurrenceAssigneeComplete() {
      let before = resource.data;
      let after = request.resource.data;
      return isTaskOccurrenceAssignee()
        && after.templateId == before.templateId
        && after.periodKey == before.periodKey
        && after.title == before.title
        && after.note == before.note
        && after.checklist == before.checklist
        && after.assigneeIds == before.assigneeIds
        && after.assigneeNames == before.assigneeNames
        && after.dueDate == before.dueDate
        && after.openAt == before.openAt
        && after.createdAt == before.createdAt
        && after.diff(before).affectedKeys().hasOnly([
          'checklistDone',
          'proofImg',
          'proofImgs',
          'status',
          'completedAt',
          'completedBy',
          'completedKind',
          'wasMissedBeforeBackfill',
          'updatedAt',
        ]);
    }

    match /taskTemplates/{id} {
      allow read, create, update, delete: if isOwner() || isOwnerEmail();
    }

    match /taskOccurrences/{id} {
      allow read: if isOwner() || isOwnerEmail() || isTaskOccurrenceAssignee();
      allow create, delete: if isOwner() || isOwnerEmail();
      allow update: if isOwner() || isOwnerEmail() || taskOccurrenceAssigneeComplete();
    }

    match /bonusDeductionMonths/{monthKey} {
      allow read: if hasPerm('bonus');
      allow write: if isOwner();
    }

    match /meta/{docId} {
      // brandLogo + businessProfile text are public (no secrets) so login can show the mark
      // aiSettings holds Gemini API key — owner-only read
      allow read: if docId == 'businessProfile'
        || docId == 'brandLogo'
        || (docId == 'aiSettings' && isOwner())
        || (docId == 'foodstoryAuth' && isOwner())
        || (docId != 'aiSettings' && docId != 'foodstoryAuth' && isStaff())
        || (isPosDeviceAuth() && (docId == 'ui' || docId == 'pos' || docId == 'posNativeRelease' || docId == 'posOpsNotes'));
      allow write: if isOwner()
        || (hasPerm('ledger') && (docId == 'ledger' || docId == 'lowBalanceAlert'))
        || (isOwner() && docId == 'lowBalanceAlert')
        || (hasPerm('ownerBooks') && docId == 'ownerBooks')
        || (isOwner() && docId == 'otSettings')
        || (isPosDeviceAuth() && docId == 'pos' && posMetaBillWrite());
    }

    match /pushSubscriptions/{id} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && hasEmail()
        && request.resource.data.email == authEmail()
        && request.resource.data.endpoint is string
        && request.resource.data.keys.keys().hasAll(['p256dh', 'auth']);
      allow delete: if isOwner() && hasEmail() && resource.data.email == authEmail();
    }

    match /menuCategories/{id} {
      allow read: if isStaff() || isPosDeviceAuth();
      allow create: if isOwner() || posMenuCategoryCreate();
      allow update, delete: if isOwner() || isPosDeviceAuth();
    }

    match /menuItems/{id} {
      allow read: if isStaff() || isPosDeviceAuth();
      allow create: if isOwner() || posMenuItemCreate();
      allow update, delete: if isOwner() || isPosDeviceAuth();
    }

    match /menuOptionGroups/{id} {
      allow read: if isStaff() || isPosDeviceAuth();
      allow create, update, delete: if isOwner() || isPosDeviceAuth();
    }

    match /posSessions/{sessionId} {
      allow read: if isOwner()
        || (isPosDeviceAuth() && (
          resource == null || resource.data.deviceId == request.auth.uid
        ));
      allow list: if isOwner();
      allow create: if isPosDeviceAuth() && posSessionOpen();
      allow update: if (isPosDeviceAuth() && (posSessionSaleBump() || posSessionClose())) || isOwner();
      allow delete: if isOwner();
    }

    match /posSales/{id} {
      allow read: if isOwner();
      allow create: if isPosDeviceAuth() && posSaleCreate();
      allow update, delete: if isOwner();
    }

    match /nposDiagnose/{installId} {
      // Written only by Admin SDK (reportNposDiagnose Cloud Function).
      allow read: if isOwner() || isOwnerEmail();
      allow write: if false;
    }

    match /nposOpsLog/{installId} {
      // Compact device timeline — Admin SDK write only (reportNposOpsLog).
      allow read: if isOwner() || isOwnerEmail();
      allow write: if false;
    }

    match /nposScreenShots/{shotId} {
      // Screen captures — Admin SDK write only (reportNposScreenCapture).
      allow read: if isOwner() || isOwnerEmail();
      allow write: if false;
    }

    match /posDevices/{deviceId} {
      allow read: if isOwner() || isOwnerEmail()
        || (isPosDeviceAuth() && deviceId == request.auth.uid);
      allow list: if isOwner() || isOwnerEmail();
      allow create: if isPosDeviceAuth()
        && deviceId == request.auth.uid
        && posDeviceCreate();
      allow update: if (isPosDeviceAuth()
          && deviceId == request.auth.uid
          && posDeviceHeartbeat())
        || ((isOwner() || isOwnerEmail()) && posDeviceOwnerPatch());
      allow delete: if isOwner() || isOwnerEmail();
    }

    match /loginTickets/{ticketId} {
      allow create: if hasEmail()
        && signedIn()
        && request.resource.data.keys().hasOnly(['idToken', 'createdAt', 'exp'])
        && request.resource.data.idToken is string
        && request.resource.data.idToken.size() > 20
        && request.resource.data.idToken.size() < 5000
        && request.resource.data.createdAt is number
        && request.resource.data.exp is number
        && request.resource.data.exp > request.time.toMillis()
        && request.resource.data.exp < request.time.toMillis() + 300000;
      allow get: if resource.data.exp > request.time.toMillis();
      allow delete: if true;
      allow list, update: if false;
    }

    // TaxTag (https://taxtag.web.app) — same Firebase project, own collection only.
    // Keep these rules here: never deploy a Tax-only firestore.rules or it wipes TellTea.
    match /taxtag/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid
        && request.auth.token.email == 'yohaken@gmail.com';
    }
  }
}
