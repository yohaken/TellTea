rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function staffPath() {
      return /databases/$(database)/documents/staff/$(email());
    }

    function isStaff() {
      return signedIn() && exists(staffPath());
    }

    function isOwner() {
      return isStaff() && get(staffPath()).data.role == 'owner';
    }

    function isOwnerEmail() {
      return signedIn() && email() == 'yohaken@gmail.com';
    }

    match /staff/{staffEmail} {
      // Own doc: any signed-in user can read (needed before isStaff() is known)
      allow get: if signedIn() && staffEmail == email();
      allow list: if isOwner();
      allow create: if isOwner()
        || (isOwnerEmail()
            && staffEmail == email()
            && request.resource.data.email == email()
            && request.resource.data.role == 'owner');
      allow update, delete: if isOwner();
    }

    match /ledger/{entryId} {
      allow read: if isStaff();
      allow create: if isStaff()
        && request.resource.data.createdBy == request.auth.token.email
        && request.resource.data.description is string
        && request.resource.data.amountIn is number
        && request.resource.data.amountOut is number
        && request.resource.data.amountIn >= 0
        && request.resource.data.amountOut >= 0
        && (
          (request.resource.data.amountIn > 0 && request.resource.data.amountOut == 0 && isOwner())
          || (request.resource.data.amountOut > 0 && request.resource.data.amountIn == 0)
        );
      // ร้านเล็ก — พนักงานแก้/ลบรายการที่บันทึกผิดได้
      allow update, delete: if isStaff();
    }

    match /stock/{itemId} {
      allow read: if isStaff();
      allow create, delete: if isOwner();
      allow update: if isStaff()
        && request.resource.data.name is string
        && request.resource.data.qty is number
        && request.resource.data.qty >= 0;
    }
  }
}
