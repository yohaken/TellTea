# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/out-pos/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
scripts/data/foodstory-auth/storage.json
scripts/data/foodstory-auth/session.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# firebase
.firebase/
firebase-debug.log
firebase-debug.*.log
functions/.env
functions/node_modules/

# local shop ledger spreadsheets (import via UI / scripts)
*.xlsx
*.xls

# android native (Capacitor) — keep project, ignore local/build noise
android/.gradle/
android/**/build/
android/local.properties
android/captures/
android/.idea/
# Build artifacts — but Hosting must still ship out-pos/downloads/*.apk
# (Firebase uses .firebaseignore; keep *.apk ignored in git only.)
*.apk
!/out-pos/downloads/*.apk
*.aab
!/out-pos/downloads/*.aab

# FoodStory menu image ZIP (import via scripts/seed-pos-menu-images.mjs)
scripts/data/menu-images-import/


