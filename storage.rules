rules_version = '2';
// Firebase Storage — TellTea app photos (mypeer-501909)
// Evidence photos (tax slips) may be up to ~10MB; rule ceiling 12MB.
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null
        && (request.auth.token.email != null || request.auth.token.phone_number != null);
    }

    function evidenceImageOk() {
      return request.resource.size < 12 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /ot-photos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && evidenceImageOk();
      allow delete: if signedIn();
    }

    match /owner-books/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && evidenceImageOk();
      allow delete: if signedIn();
    }

    match /ledger-receipts/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && evidenceImageOk();
      allow delete: if signedIn();
    }
  }
}
