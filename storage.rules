rules_version = '2';
// Firebase Storage — TellTea app photos (mypeer-501909)
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null
        && (request.auth.token.email != null || request.auth.token.phone_number != null);
    }

    match /ot-photos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if signedIn();
    }

    match /owner-books/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if signedIn();
    }

    match /ledger-receipts/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if signedIn();
    }
  }
}
