rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /** POS menu item photos — readable by anyone (sell screen), writable by POS device. */
    match /pos-menu/{itemId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.posDevice == true
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.token.posDevice == true;
    }
  }
}
